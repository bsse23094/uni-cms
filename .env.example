# Supabase Project Credentials
# Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service Role key (server-side only – NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (used for OAuth redirects and email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Supabase Storage bucket names
NEXT_PUBLIC_ASSIGNMENTS_BUCKET=assignments
NEXT_PUBLIC_SUBMISSIONS_BUCKET=submissions
NEXT_PUBLIC_AVATARS_BUCKET=avatars
